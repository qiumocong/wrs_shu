          popup("1837:exportWaitUntilActivatedFunction","Exception", blocking = True)
        end
      end
      if ("UNDEFINE" == response):
        while (True):
          popup("1854:exportWaitUntilActivatedFunction","Exception", blocking = True)
        end
      end
      if ("ACTIVATED" == response):
        ret = True
        break
      end
    end
    return ret
  end
  
  
  def dh_pgc_wait_until_gripped(installation_index):
