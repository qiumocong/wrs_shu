      end
    end
    return ret
  end
  
  
  def dh_pgc_wait_until_gripped_or_arrived(installation_index):
    local response = "UNDEFINE"
    local ret = False
    while (True):
      response = dh_pgc_get_gripper_status(installation_index)
      if ("" == response):
        while (True):
          popup("1956:exportWaitUntilGrippedOrArrivedFunction","Exception", blocking = True)
        end
      end
      if ("UNDEFINE" == response):
        while (True):
          popup("1973:exportWaitUntilGrippedOrArrivedFunction","Exception", blocking = True)
        end
      end
      if ("ARRIVED" == response):
        ret = True
        break
      end
      if ("DETECTED" == response):
        ret = True
        break
      end
      if ("DROPPED" == response):
        ret = True
        break
      end
    end
    return ret
  end
  
