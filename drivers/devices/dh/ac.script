      dh_pgc_connected_to_server = "True"
    end
  end
  def dh_pgc_is_connected_to_server():
    return dh_pgc_connected_to_server
  end
  def dh_pgc_lock():
    enter_critical
    while (True):
      if (dh_pgc_global_lock == False):
        dh_pgc_global_lock = True
        break
      end
      sleep(0.1)
    end
    exit_critical
  end
  def dh_pgc_unlock():
    enter_critical
    while (True):
      if (dh_pgc_global_lock == True):
        dh_pgc_global_lock = False
        break
      end
      sleep(0.1)
    end
    exit_critical
  end
  
  
  def dh_pgc_scan():
    local ret = False
    local operate = True
    dh_pgc_lock()
    operate = operate and socket_send_line("String scan()", "dh_pgc_")
