  def dh_pgc_wait_until_idle(installation_index):
    local response = "UNDEFINE"
    local ret = False
    while (True):
      response = dh_pgc_get_gripper_status(installation_index)
      if ("" == response):
        while (True):
          popup("1773:exportWaitUntilIdle","Exception", blocking = True)
        end
      end
      if ("UNDEFINE" == response):
        while (True):
          popup("1790:exportWaitUntilIdle","Exception", blocking = True)
        end
      end
      if ("ACTIVATING" == response):
        continue
      end
      if ("MOVING" == response):
        continue
      end
      ret = True
      break
    end
    return ret
  end
  
  
  def dh_pgc_wait_until_activated(installation_index):
    local response = "UNDEFINE"
    local ret = False
    while (True):
      response = dh_pgc_get_gripper_status(installation_index)
      if ("" == response):
