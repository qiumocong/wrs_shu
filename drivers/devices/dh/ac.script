    local ret = True
    if ("UNDEFINE" == response):
      ret = False
    end
    if ("INACTIVATE" == response):
      ret = False
    end
    if ("ACTIVATING" == response):
      ret = False
    end
    return ret
  end
  
  
  def dh_pgc_set_activate(installation_index):
