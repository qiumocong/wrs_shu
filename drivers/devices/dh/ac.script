  def dh_pgc_connect(installation_index):
    local ret = False
    while (True):
      local operate = True
      dh_pgc_lock()
      operate = operate and socket_send_line("String connect(int installationIndex)", "dh_pgc_")
      operate = operate and socket_send_line(installation_index, "dh_pgc_")
      while (False == operate):
        popup("712:exportConnectFunction","socket_send_line", blocking = True)
      end
      local response = "SUCCEEDED"
      response = socket_read_line("dh_pgc_")
      dh_pgc_unlock()
      ret = "SUCCEEDED"== response
      if (True == ret):
        break
      end
      if ("PARAMETERS_FAILED" == response):
        while (True):
          popup("Please check installation configuration","Tip", blocking = True)
        end
      end
      break
    end
    return ret
  end
  
  
