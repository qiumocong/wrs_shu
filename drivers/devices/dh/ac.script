      popup("移动前，请先激活夹爪","提示", blocking = True)
    end
  end
  while (True):
    dh_pgc_operate = program_replace_force
    if (True ==dh_pgc_operate):
      break
    end
    sleep(0.1)
  end
  while (True):
    dh_pgc_operate = program_replace_speed
    if (True ==dh_pgc_operate):
      break
    end
    sleep(0.1)
  end
